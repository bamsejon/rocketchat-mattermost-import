# Mattermost
MM_URL=https://mattermost.example.com
MM_TOKEN=your-personal-access-token
MM_TEAM=myteam
MM_CHANNEL=general

# MongoDB (via kubectl port-forward)
MONGO_URI=mongodb://localhost:27017/rocketchat

# Rocket.Chat
RC_ROOM_ID=GENERAL
FALLBACK_USER=admin
USER_MODE=email

# Optional manual mapping (JSON)
# USER_MAPPING={"mm_user@email.com": "rc_username"}
